# --- Core ---
DJANGO_SECRET_KEY="6a8a6ba3-6de0-40e7-a0ba-4e31e60dd9bb"
DJANGO_DEBUG="True"

# Which settings module to load: config.settings.development | config.settings.production
DJANGO_SETTINGS_MODULE="config.settings.development"

# Space- or comma-separated list of allowed hosts
DJANGO_ALLOWED_HOSTS="localhost,127.0.0.1"

# --- Database (PostgreSQL) ---
# Single connection string. Format:
#   postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL="postgres://postgres:root@localhost:5432/ai_workflow"

# --- CORS / CSRF (frontend origin) ---
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# --- JWT lifetimes (minutes / days) ---
JWT_ACCESS_TOKEN_LIFETIME_MIN=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
